FROM python:3.11-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN git clone --depth 1 https://github.com/GitUser200607/deepseek-free-api.git . \
    && pip install --no-cache-dir -r requirements.txt

EXPOSE 8000

CMD ["python", "proxy.py"]
