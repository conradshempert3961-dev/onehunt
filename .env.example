BOT_TOKEN=your_telegram_bot_token
DATABASE_URL=postgresql+asyncpg://onehunt:onehunt@postgres:5432/onehunt
REDIS_URL=redis://redis:6379/0
ADMIN_IDS=
QUESTIONS_FILE=/app/questions.json
EXPORT_DIR=/app/data
ANIMAL_CARDS_FILE=/app/data/animal_cards.json
QUOTES_FILE=/app/data/quotes.json
EXAM_QUESTIONS=257
EXAM_PASS_PERCENT=75
BLOCK_QUESTIONS=10
USE_REDIS_FSM=false
APP_TIMEZONE=Europe/Moscow
FREE_MODE=false
BOT_SHELL_MODE=true
ANSWER_BUTTONS_LAYOUT=single_row
MINIAPP_URL=http://127.0.0.1:8080/
MINIAPP_DEV_USER_ID=
MINIAPP_PORT=8080
MINIAPP_SESSION_TTL_MINUTES=240
MINIAPP_BROWSER_DEMO=false
MINIAPP_BROWSER_DEMO_HOSTS=localhost,127.0.0.1,::1
TELEGRAM_PROXY=
# If VDS cannot reach api.telegram.org, set proxy base (e.g. Cloudflare tunnel to telegram_edge_proxy)
# TELEGRAM_API_BASE=https://your-tunnel.trycloudflare.com
TELEGRAM_STARS_PROVIDER_TOKEN=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://t.me/onehunt_exam_bot
PAYMENTS_WEBHOOK_SECRET=
YOOMONEY_WALLET=
YOOMONEY_ACCESS_TOKEN=
YOOMONEY_NOTIFICATION_SECRET=
YOOMONEY_RETURN_URL=https://huntexam.online/
YOOMONEY_LABEL_PREFIX=onehunt
CRYPTO_PAY_API_TOKEN=
CRYPTO_PAY_API_BASE_URL=https://pay.crypt.bot/api
CRYPTO_PAY_RETURN_URL=https://huntexam.online/
CRYPTO_PAY_ACCEPTED_ASSETS=TON,USDT
CRYPTO_PAY_EXPIRES_IN=3600

# AI assistant — Groq (рекомендуется на VDS) или любой OpenAI-compatible API.
# Без OPENAI_API_KEY приложение отвечает по шаблону (rule-based).
# Groq on VDS: use proxy URL (api.groq.com is blocked from datacenter IPs)
# OPENAI_API_BASE=https://your-groq-proxy.workers.dev/openai/v1
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_MODEL=groq/compound-mini
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.4
AI_REQUEST_TIMEOUT=45
AI_MAX_HISTORY=8
