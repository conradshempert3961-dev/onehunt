BOT_TOKEN=your_telegram_bot_token
ADMIN_IDS=6467055041

# Local Windows run uses SQLite by default. run_all_local.ps1 overrides this
# with an absolute path under ./data.
DATABASE_URL=sqlite+aiosqlite:///./data/onehunt_local.db
USE_REDIS_FSM=false

QUESTIONS_FILE=questions.json
EXPORT_DIR=data
ANIMAL_CARDS_FILE=data/animal_cards.json
QUOTES_FILE=data/quotes.json

FREE_MODE=true
BOT_SHELL_MODE=true
ANSWER_BUTTONS_LAYOUT=single_row

# Telegram Web Apps require HTTPS. Local http://127.0.0.1:8080 works in a
# browser, but should not be used as a Telegram WebApp button.
MINIAPP_URL=
MINIAPP_DEV_USER_ID=6467055041
MINIAPP_HOST=0.0.0.0
MINIAPP_SESSION_TTL_MINUTES=240
MINIAPP_BROWSER_DEMO=true
MINIAPP_BROWSER_DEMO_HOSTS=localhost,127.0.0.1,::1

TELEGRAM_PROXY=
YOOMONEY_WALLET=
YOOMONEY_ACCESS_TOKEN=
YOOMONEY_NOTIFICATION_SECRET=
YOOMONEY_RETURN_URL=
YOOMONEY_LABEL_PREFIX=onehunt-local

# AI assistant — DeepSeek Free API (локальный OpenAI-совместимый прокси)
#
# Mac / Windows (локально):
#   bash scripts/bootstrap_deepseek_proxy.sh
#   cd tools/deepseek-free-api && node server.mjs --login
#   node server.mjs   → http://127.0.0.1:18632
#
# VDS (без браузера на сервере — токен с вашего ПК):
#   chat.deepseek.com → F12 → Application → Local Storage → userToken → value
#   /opt/onehunt/.env.deepseek → DEEPSEEK_USER_TOKEN=...
#   bash scripts/setup_deepseek_vds.sh
#
OPENAI_API_KEY=sk-dummy
OPENAI_API_BASE=http://127.0.0.1:18632/v1
OPENAI_MODEL=deepseek-chat
AI_REQUEST_TIMEOUT=90
AI_MAX_TOKENS=800
AI_TEMPERATURE=0.4
AI_MAX_HISTORY=8
